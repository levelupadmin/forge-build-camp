# Razorpay webhook secret — set this in:
#   Razorpay Dashboard → Settings → Webhooks → Add → "Webhook secret"
# Razorpay signs every webhook payload with HMAC-SHA256(payload, this_secret).
# Our /api/razorpay-webhook verifies the signature using this value.
RAZORPAY_WEBHOOK_SECRET=replace_me

# Resend API key — generate at https://resend.com/api-keys
# Use a key with "Send emails" permission only. Keep this server-side ONLY.
RESEND_API_KEY=re_replace_me

# Sender identity. The domain on FROM_EMAIL MUST be verified in Resend
# (3 DNS records: SPF, DKIM, and one for Resend's identity).
FROM_EMAIL=forge@leveluplearning.in
FROM_NAME=The Forge by LevelUp
REPLY_TO_EMAIL=forge@leveluplearning.in
